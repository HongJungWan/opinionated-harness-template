{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_doc": "하네스 훅 배선(팀 공유, 커밋됨). 룰은 .claude/hooks/harness.config.json 에서 수정.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/harness.mjs\" protect",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/harness.mjs\" bash",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/harness.mjs\" guard",
            "timeout": 15,
            "statusMessage": "DDD 가드 검사 중..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/harness.mjs\" checklist",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
