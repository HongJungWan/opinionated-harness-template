{
  "_doc": "프로젝트별로 이 파일만 고치면 된다. layers/forbiddenImports/forbiddenContentPatterns/protectedPaths/forbiddenCommands. (Java/Spring 기본값, 실용 레이어드)",
  "commandRule": "Gradle wrapper(./gradlew)만 사용하세요. mvn / 전역 gradle 금지.",
  "importPatterns": ["import\\s+(?:static\\s+)?([\\w.]+)\\s*;"],
  "sourceExtensions": [".java", ".kt"],
  "sourceRootMarkers": ["src/main/java", "src/main/kotlin", "src/test/java"],
  "markers": {
    "aggregateRoot": "AggregateRoot", "aggregateInternal": "AggregateInternal",
    "valueObject": "ValueObject", "domainEvent": "DomainEvent", "domainService": "DomainService"
  },
  "thresholds": { "maxAggregateFields": 12 },
  "_checksDoc": "신규 DDD 체크 severity: block(차단,exit2) | warn(권고,exit0) | off. 기본은 모두 block. 휴리스틱이 오탐으로 시끄러우면 warn/off로 낮춘다. 구조 규칙 정밀 강제는 ArchUnit(CI).",
  "checks": {
    "vodImmutability": "block",
    "repositoryInterface": "block",
    "aggregateBoundary": "block",
    "idReference": "block",
    "anemicModel": "block",
    "minAggregate": "block",
    "domainServiceStateless": "block",
    "domainFactory": "block",
    "pastTenseEvent": "block"
  },
  "layers": {
    "presentation": ["**/controller/**", "**/controllers/**", "**/web/**", "**/presentation/**"],
    "domain": ["**/domain/**"],
    "application": ["**/application/**", "**/usecase/**", "**/usecases/**"],
    "infrastructure": ["**/infrastructure/**", "**/infra/**", "**/adapter/**", "**/adapters/**"]
  },
  "forbiddenImports": {
    "_strictMode": "순수 헥사고날로 전환하려면 아래 domain 배열에 jakarta.persistence, org.springframework, lombok 을 추가. 기본은 실용 레이어드(허용).",
    "domain": [
      ".infra.", "infrastructure", ".adapter.", ".adapters.",
      ".application.", ".usecase.", ".controller.", ".presentation.",
      "software.amazon.awssdk", "RestTemplate", "WebClient", "feign", "okhttp3",
      "ApplicationEventPublisher", "EventBus", "org.springframework.context.event"
    ],
    "application": [
      ".infra.", "infrastructure", ".adapter.", ".adapters.",
      "JdbcTemplate", "software.amazon.awssdk", "RestTemplate", "WebClient", "feign", "okhttp3"
    ]
  },
  "forbiddenContentPatterns": [
    { "pattern": "@Autowired(?![^;{]*\\()", "message": "필드 주입 금지: 생성자 주입을 사용하세요 (@Autowired 필드)." },
    { "pattern": "@Setter\\b", "layers": ["domain"], "message": "도메인 캡슐화 위반: @Setter 금지(가변 노출). 의미있는 행위 메서드로 상태를 바꾸세요." },
    { "pattern": "@Data\\b", "layers": ["domain"], "message": "도메인 캡슐화 위반: @Data 금지(setter+가변 노출). @Getter/@Value 등으로 대체하세요." },
    { "pattern": "public\\s+\\w[\\w<>\\[\\].]*\\s+set[A-Z]\\w*\\s*\\(", "layers": ["domain"], "message": "도메인 캡슐화 위반: public setter 금지(빈약 모델). 행위 메서드로 캡슐화하세요." },
    { "pattern": "@(RestController|Controller|Service|Component|Repository|Transactional)\\b", "layers": ["domain"], "message": "도메인 순수성 위반: Spring 스테레오타입/@Transactional 금지. 도메인 모델은 컨테이너에서 분리하세요." },
    { "pattern": "\\b(LocalDateTime|Instant|LocalDate|LocalTime|ZonedDateTime|OffsetDateTime)\\s*\\.\\s*now\\s*\\(", "layers": ["domain"], "message": "시간 API 직접 호출 금지: 도메인은 Clock 또는 시간 포트를 주입받아 호출하세요." },
    { "pattern": "\\bSystem\\s*\\.\\s*(currentTimeMillis|nanoTime)\\s*\\(", "layers": ["domain"], "message": "시스템 시계 직접 호출 금지: 도메인은 Clock 포트를 주입받으세요." },
    { "pattern": "\\bnew\\s+(java\\.util\\.)?Random\\s*\\(", "layers": ["domain"], "message": "난수 직접 생성 금지: 도메인은 RandomProvider 포트를 주입받으세요." },
    { "pattern": "\\bMath\\s*\\.\\s*random\\s*\\(", "layers": ["domain"], "message": "난수 직접 호출 금지: 도메인은 RandomProvider 포트를 주입받으세요." },
    { "pattern": "\\bUUID\\s*\\.\\s*randomUUID\\s*\\(", "layers": ["domain"], "message": "UUID 직접 생성 금지: 도메인은 IdGenerator 포트를 주입받으세요." }
  ],
  "forbiddenFilenames": {
    "_doc": "DIP: 구현체는 infrastructure 에. 도메인엔 리포지토리 인터페이스만.",
    "domain": ["RepositoryImpl$", "RepositoryCustomImpl$"]
  },
  "protectedPaths": ["**/src/main/resources/db/migration/**", "**/db/migration/**", "**/db/changelog/**"],
  "forbiddenCommands": ["(^|\\s)mvn(\\s|$)", "(^|\\s)gradle(\\s|$)"]
}
